<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="2.2" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence           http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
      
    <persistence-unit name="org.example_project_7_war_1.0-SNAPSHOTPU" transaction-type="RESOURCE_LOCAL">
            
        <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
            
        <class>com.example.project_7.entity.ExamAttendance</class>
            
        <class>com.example.project_7.entity.Student</class>
            
        <class>com.example.project_7.entity.Scheduler</class>
            
        <class>com.example.project_7.entity.Exam</class>
            
        <exclude-unlisted-classes>false</exclude-unlisted-classes>
            
        <properties>
                  
            <property name="javax.persistence.jdbc.url" value="jdbc:mysql://localhost:4306/exam_db?zeroDateTimeBehavior=CONVERT_TO_NULL"/>
                  
            <property name="javax.persistence.jdbc.user" value="root"/>
                  
            <property name="javax.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
                  
            <property name="javax.persistence.jdbc.password" value=""/>
                
        </properties>
          
    </persistence-unit>
    
</persistence>
