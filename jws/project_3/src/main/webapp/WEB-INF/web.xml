<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://java.sun.com/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://java.sun.com/xml/ns/javaee
         http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd"
         version="2.5">

    <display-name>Computer Service - JAX-WS</display-name>
    <description>JAX-WS Web Service for Computer Management</description>

    <!-- JAX-WS Listener -->
    <listener>
        <listener-class>com.sun.xml.ws.transport.http.servlet.WSServletContextListener</listener-class>
    </listener>

    <!-- JAX-WS Servlet -->
    <servlet>
        <servlet-name>ComputerServiceServlet</servlet-name>
        <servlet-class>com.sun.xml.ws.transport.http.servlet.WSServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <!-- Servlet Mapping for JAX-WS -->
    <servlet-mapping>
        <servlet-name>ComputerServiceServlet</servlet-name>
        <url-pattern>/ComputerService</url-pattern>
    </servlet-mapping>

    <!-- Application Parameter for Database Configuration -->
    <context-param>
        <param-name>jdbc.url</param-name>
        <param-value>jdbc:sqlserver://localhost:1433;databaseName=ComputerDB</param-value>
    </context-param>
    <context-param>
        <param-name>jdbc.user</param-name>
        <param-value>sa</param-value>
    </context-param>
    <context-param>
        <param-name>jdbc.password</param-name>
        <param-value></param-value>
    </context-param>

    <session-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

</web-app>
